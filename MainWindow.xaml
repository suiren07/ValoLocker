<Window x:Class="ValoLocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ValoLocker"
        mc:Ignorable="d"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Background="#000"
        BorderBrush="#bbffffff"
        BorderThickness="1"
        Title="ValoLocker" Height="400" Width="350">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="29"/>
            <RowDefinition Height="1"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid x:Name="TitleBar" Grid.Row="0" Height="29" Margin="0" VerticalAlignment="Top" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="134"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="45"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnLogo" Grid.Column="0" Style="{StaticResource btnLogo}">
                <Image Source="Images/btnLogo.png"/>
            </Button>
            <Button x:Name="btnMinimize" Grid.Column="2" Style="{StaticResource btnTitle}" Click="btnMinimize_Click">
                <Image Source="Images/btnMinimize.png"/>
            </Button>
            <Button x:Name="btnClose" Grid.Column="3" Style="{StaticResource btnClose}" Click="btnClose_Click">
                <Image Source="Images/btnClose.png"/>
            </Button>
        </Grid>
        <Grid Grid.Row="2" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Width="150" Height="25" BorderBrush="#bbffffff" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30, 0, 0, 0">
                <Button x:Name="MapDropdownButton" Click="MapDropdown_Click">
                    <Grid Width="150">
                        <Label x:Name="labelSelectedMap" Content="Default" HorizontalAlignment="Left" Margin="3, 0, 0, 0"/>
                        <Label x:Name="labelSelectedMap2" Content="-" HorizontalAlignment="Right" Margin="0, 0, 5, 0"/>
                    </Grid>
                </Button>
            </Border>
            <Popup x:Name="MapDropdownPopup" StaysOpen="False" HorizontalOffset="-1" VerticalOffset="-1">
                <Border BorderBrush="#bbffffff" BorderThickness="1, 0, 1, 1">
                    <ItemsControl x:Name="maps">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="MapDropdownItem_Click" Visibility="{Binding Visibility}">
                                    <Grid Width="148">
                                        <Label Content="{Binding DisplayName}" HorizontalAlignment="Left" Margin="3, 0, 0, 0"/>
                                        <Label Content="{Binding AgentDisplayName}" HorizontalAlignment="Right" Margin="0, 0, 3, 0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Popup>
            <ScrollViewer Grid.Row="3" Width="300" Height="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ItemsControl x:Name="agents">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton GroupName="Agents" Click="AgentButton_Click" Width="67" Height="67" Margin="1.5" IsChecked="{Binding IsChecked, Mode=TwoWay}">
                                <Image Source="{Binding DisplayIcon}"/>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Grid Grid.Row="5">
                <Border BorderBrush="#bbffffff" BorderThickness="1" Width="130" Margin="30, 0, 0, 0" HorizontalAlignment="Left">
                    <Grid>
                        <Button x:Name="btnToggle" Margin="0, 0, 28, 0" Content="Toggle" Width="100" Height="40" HorizontalAlignment="Left" Click="btnToggle_Click"/>
                        <Rectangle x:Name="rectToggle" Margin="100, 0, 0, 0" Fill="#1febad" Width="30" Height="40" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <Label Margin="0, 0, 30, 0" x:Name="labelStatus" Content="Valorant not open..." Width="150" Height="40" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
